# =============================================================================
# Database Configuration
# =============================================================================

# Production database settings
POSTGRES_DB=vector
POSTGRES_HOST=db
POSTGRES_USER=vector
POSTGRES_PASSWORD=vector
POSTGRES_PORT=5432

# Connection pool settings
POSTGRES_CONNECT_TIMEOUT=5
POSTGRES_POOL_MIN_SIZE=1
POSTGRES_POOL_MAX_SIZE=5
POSTGRES_POOL_TIMEOUT=5

# Optional: set DATABASE_URL to override the POSTGRES_* connection fields
# DATABASE_URL=postgresql://vector:vector@db:5432/vector

# =============================================================================
# Test Database Configuration
# =============================================================================

TEST_POSTGRES_DB=vector_test
TEST_POSTGRES_HOST=db
TEST_POSTGRES_USER=vector
TEST_POSTGRES_PASSWORD=vector
TEST_POSTGRES_PORT=5432

# Test connection pool settings
TEST_POSTGRES_CONNECT_TIMEOUT=5
TEST_POSTGRES_POOL_MIN_SIZE=1
TEST_POSTGRES_POOL_MAX_SIZE=5
TEST_POSTGRES_POOL_TIMEOUT=5

# =============================================================================
# Backend API Configuration
# =============================================================================

BACKEND_PORT=8000
FRONTEND_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

# =============================================================================
# Frontend Configuration
# =============================================================================

FRONTEND_PORT=5173
VITE_API_BASE_URL=/api
VITE_API_PROXY_TARGET=http://backend:8000

# =============================================================================
# PgAdmin Configuration
# =============================================================================

PGADMIN_DEFAULT_EMAIL=admin@example.com
PGADMIN_DEFAULT_PASSWORD=vector
PGADMIN_PORT=5050
