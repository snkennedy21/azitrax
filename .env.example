# =============================================================================
# Production Docker Compose Configuration
# =============================================================================

COMPOSE_PROJECT_NAME=azitrax

# Paste only the token value from Cloudflare's Docker tunnel command.
CLOUDFLARED_TUNNEL_TOKEN=<CLOUDFLARED_TUNNEL_TOKEN>

# =============================================================================
# Production Database Configuration
# =============================================================================

POSTGRES_DB=azitrax
POSTGRES_HOST=db
POSTGRES_USER=azitrax
POSTGRES_PASSWORD=<CHANGE_ME_STRONG_POSTGRES_PASSWORD>
POSTGRES_PORT=5432

POSTGRES_CONNECT_TIMEOUT=5
POSTGRES_POOL_MIN_SIZE=1
POSTGRES_POOL_MAX_SIZE=5
POSTGRES_POOL_TIMEOUT=5

# Leave DATABASE_URL unset unless you want to override the POSTGRES_* fields.
# DATABASE_URL=postgresql://azitrax:<CHANGE_ME_STRONG_POSTGRES_PASSWORD>@db:5432/azitrax

# =============================================================================
# Backend API Configuration
# =============================================================================

BACKEND_PORT=8000
FRONTEND_ORIGINS=https://azitrax.com

# =============================================================================
# AIS Source Configuration
# =============================================================================

AISSTREAM_API_KEY=<AISSTREAM_API_KEY>
AISSTREAM_WS_URL=wss://stream.aisstream.io/v0/stream
AISSTREAM_BOUNDING_BOXES=[[[40.4774,-74.2591],[40.9176,-73.7004]]]
AISSTREAM_MESSAGE_TYPES=PositionReport
AISSTREAM_CONNECT_TIMEOUT_SECONDS=200
AISSTREAM_SAMPLE_MESSAGE_LIMIT=50
AISSTREAM_DISABLE_TLS_VERIFY=false

AIS_CONSUMER_POLL_SECONDS=60
AIS_CONSUMER_RUN_ONCE=false
AIS_CONSUMER_RECONNECT_BACKOFF_SECONDS=5

# =============================================================================
# Local Development Only
# =============================================================================

TEST_POSTGRES_DB=azitrax_test
TEST_POSTGRES_HOST=db
TEST_POSTGRES_USER=azitrax
TEST_POSTGRES_PASSWORD=azitrax
TEST_POSTGRES_PORT=5432

TEST_POSTGRES_CONNECT_TIMEOUT=5
TEST_POSTGRES_POOL_MIN_SIZE=1
TEST_POSTGRES_POOL_MAX_SIZE=5
TEST_POSTGRES_POOL_TIMEOUT=5

REDIS_URL=redis://redis:6379/0
REDIS_PORT=6379

FRONTEND_PORT=5173
VITE_API_BASE_URL=/api
VITE_API_PROXY_TARGET=http://backend:8000

PGADMIN_DEFAULT_EMAIL=admin@example.com
PGADMIN_DEFAULT_PASSWORD=azitrax
PGADMIN_PORT=5050
